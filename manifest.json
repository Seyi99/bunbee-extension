{
  "manifest_version": 3,
  "name": "Bunbee for WaniKani",
  "version": "1.0.0",
  "description": "Mnemonics and AI sentence generation from Bunbee, right inside your WaniKani reviews.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.wanikani.com/subjects/review*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://api.bunbee.cc/*",
    "https://www.wanikani.com/*",
    "https://api.wanikani.com/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "bunbee@bunbee.cc",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo", "personallyIdentifyingInfo"]
      }
    }
  }
}
